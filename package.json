{
  "name": "ecom-dashboard",
  "version": "2.0.0",
  "description": "ECOM Dashboard — Express + PostgreSQL backend + React frontend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client:dev": "vite",
    "client:build": "vite build",
    "deploy": "vite build && cp dist/index.html ./index.html && cp -r dist/assets ./",
    "db:init": "psql $DATABASE_URL -f schema.sql",
    "init-db": "node scripts/init-production-db.js",
    "set-admin": "node scripts/set-admin-users.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "chart.js": "^4.4.9",
    "nodemon": "^3.1.0",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "vite": "^8.0.1"
  }
}
